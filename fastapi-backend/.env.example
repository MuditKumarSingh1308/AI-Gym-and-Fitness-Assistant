# FastAPI backend
APP_NAME=AI Gym Fitness Assistant API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai_gym_fitness?retryWrites=true&w=majority
MONGODB_DB_NAME=ai_gym_fitness

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# AI / Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.6

# Smart gym / storage
NEARBY_GYM_PROVIDER=mock
STORAGE_PROVIDER=firebase
STORAGE_BUCKET=ai-gym-fitness-media
STORAGE_REGION=us-central1
